@page "/customer/applications/{Id:int}/timeline"
@attribute [Authorize(Roles = AppRoles.Customer)]

@using System.Security.Claims
@using LoanFlow.Application.LoanApplications

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILoanApplicationReadService LoanApplicationReadService

<PageTitle>Application Timeline</PageTitle>

<section class="dashboard-shell">
    <p class="dashboard-kicker">Customer Applications</p>
    <h1>Application timeline</h1>
    <p class="dashboard-text">
        This shows the events for your submitted application in time order.
    </p>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }

    <div class="dashboard-card">
        @if (timeline.Count == 0)
        {
            <p class="mb-0">The submitted application timeline could not be found.</p>
        }
        else
        {
            @foreach (var item in timeline)
            {
                <div class="timeline-item">
                    <p class="dashboard-card-label mb-1">@item.EventName</p>
                    <p class="mb-1">@item.OccurredAtUtc.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</p>
                    <p class="mb-0">@item.Description</p>
                </div>
            }
        }
    </div>

    <div class="mt-3">
        <a class="btn btn-outline-secondary" href="@CustomerApplicationWizardRoutes.GetViewPath(Id)">Back to Details</a>
    </div>
</section>

@code {
    [Parameter]
    public int Id { get; set; }

    private IReadOnlyList<LoanApplicationTimelineItem> timeline = [];
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            var customerUserId = await GetCustomerUserIdAsync();
            timeline = await LoanApplicationReadService.GetTimelineForCustomerAsync(customerUserId, Id);
        }
        catch (Exception exception) when (exception is InvalidOperationException)
        {
            errorMessage = exception.Message;
        }
    }

    private async Task<string> GetCustomerUserIdAsync()
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authenticationState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(userId))
        {
            throw new InvalidOperationException("The signed-in customer could not be found.");
        }

        return userId;
    }
}
