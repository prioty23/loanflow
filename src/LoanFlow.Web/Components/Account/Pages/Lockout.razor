@page "/Account/Lockout"

<PageTitle>Locked out</PageTitle>

<div class="mt-4">
    <h1 class="text-danger">Account temporarily locked</h1>
    <p class="lead" role="alert">Too many failed sign-in attempts were detected.</p>
    <p>Please wait a few minutes and then try again with the correct password.</p>
    <a class="btn btn-primary" href="/Account/Login">Back to sign in</a>
</div>
