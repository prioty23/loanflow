@page "/customer/dashboard"
@attribute [Authorize(Roles = AppRoles.Customer)]

<PageTitle>Customer Dashboard</PageTitle>

<section class="dashboard-shell">
    <p class="dashboard-kicker">Customer Dashboard</p>
    <h1>Welcome, customer.</h1>
    <p class="dashboard-text">
        This protected page is the starting point for customer self-service actions in LoanFlow.
    </p>

    <article class="dashboard-card">
        <p class="dashboard-card-label">Role Access</p>
        <h2>Customer tools only</h2>
        <p>
            You can open customer pages, review your own requests later, and manage your account.
        </p>
    </article>

    <article class="dashboard-card">
        <p class="dashboard-card-label">Profile</p>
        <h2>Keep your information up to date</h2>
        <p>
            Add your personal details before starting the later loan-application steps.
        </p>
        <a class="btn btn-primary" href="@RoleDashboardRoutes.CustomerProfile">Open profile</a>
    </article>

    <article class="dashboard-card">
        <p class="dashboard-card-label">Applications</p>
        <h2>Start or continue a draft</h2>
        <p>
            Open your private list, start a new application, or continue the unfinished step for an existing draft.
        </p>
        <a class="btn btn-primary" href="@RoleDashboardRoutes.CustomerApplications">Open applications</a>
    </article>
</section>
